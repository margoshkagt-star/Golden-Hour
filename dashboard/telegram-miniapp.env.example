# Telegram Mini App — переменные окружения
# Скопируйте нужные строки в %USERPROFILE%\.openclaw\.env
# (или задайте через системные переменные / export в Linux)

# Обязательно для кнопки меню и проверки initData
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Опционально: отдельный бот только для Mini App
# TELEGRAM_MINIAPP_BOT_TOKEN=

# Публичный HTTPS URL dashboard (без /miniapp на конце)
# Пример: https://xxxx.trycloudflare.com или https://dash.example.com
TELEGRAM_MINIAPP_URL=

# Текст кнопки меню слева от поля ввода в чате с ботом
TELEGRAM_MINIAPP_MENU_TEXT=📋 Задачи

# Путь к OpenClaw home (если не %USERPROFILE%\.openclaw)
# OPENCLAW_HOME=C:\Users\You\.openclaw
