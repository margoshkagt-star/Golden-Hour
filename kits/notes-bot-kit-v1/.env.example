# ============================================================================
# Notes-Bot Kit — environment variables
# ============================================================================
# Скопируй этот файл в `~/.openclaw/.env` и заполни реальный токен.
#
# Где взять токен:
#   1. Открой Telegram, найди @BotFather (https://t.me/BotFather)
#   2. Отправь /newbot, задай имя и username (например @MyTeamIdeasBot)
#   3. Скопируй токен вида `1234567890:AAHxYz...` сюда
#   4. Обязательно пошли боту /start со своего аккаунта, чтобы он знал твой chat_id
#
# ВАЖНО:
#   - .env — единственный источник правды для секретов. НЕ коммить в git.
#   - Переменная ниже ОБЯЗАТЕЛЬНА. Бот упадёт при старте без неё.
# ============================================================================

# Telegram bot token (от @BotFather)
# Используется ОБОИМИ именами для обратной совместимости.
# TEAM_BOT_TOKEN — приоритетное имя (наследие команды).
# TELEGRAM_BOT_TOKEN — fallback, если TEAM_BOT_TOKEN не задан.
TEAM_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=

# Опционально: путь к Python, если системный python — WindowsApps stub.
# По умолчанию скрипт использует `sys.executable` того интерпретатора,
# который его запускает. Раскомментируй, если хочешь жёстко зафиксировать путь.
# NOTES_BOT_PYTHON=C:\Users\Admin\AppData\Local\Programs\Python\Python312\python.exe
