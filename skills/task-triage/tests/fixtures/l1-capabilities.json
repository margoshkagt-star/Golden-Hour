{
  "level": "L1-unit",
  "category": "capability-classification",
  "description": "Проверка классификации подзадач по capability (🟢/🟡/🔴).",
  "cases": [
    {
      "id": "5.1",
      "subtask": "Написать код функции сортировки",
      "expected": {
        "capability": "self",
