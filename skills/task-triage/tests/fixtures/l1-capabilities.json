      }
    },
    {
      "id": "5.8",
      "subtask": "Оплатить счёт за хостинг",
      "expected": {
        "capability": "user-only",
        "reasoning_contains_any": ["финансы", "user-only", "не выполнимо"]
      }
    },
    {
      "id": "5.9",
      "subtask": "Позвонить маме",
      "expected": {
        "capability": "user-only",
        "reasoning_contains_any": ["голос", "user-only", "реальное"]
