{
  "level": "L1-unit",
  "category": "categories",
  "description": "Проверка категоризации (включая мульти-категорийность и создание новых категорий).",
  "cases": [
    {
      "id": "3.1",
      "title": "Подготовить презентацию для инвесторов",
      "expected": {
        "categories_must_contain_any": ["работа", "проект", "срочное"],
        "categories_count_min": 3
      }
    },
    {
      "id": "3.2",
      "title": "Пробежать 5 км",
      "expected": {
        "categories_must_contain": ["здоровье"]
      }
    },
    {
      "id": "3.3",
      "title": "Разобрать бэклог Telegram",
      "expected": {
        "categories_must_contain_any": ["работа", "коммуникации"],
        "categories_count_min": 2,
        "is_multicategory": true
      }
    },
    {
      "id": "3.4",
      "title": "Покрасить дачный забор",
      "expected": {
        "new_category_created": true,
        "new_category_suggestion": ["дача", "участок", "дом-загородный"]
      }
    },
    {
      "id": "3.5",
      "title": "Сходить в бар с коллегами",
      "expected": {
        "categories_count_min": 2,
        "is_multicategory": true
      }
    },
    {
      "id": "3.6",
      "title": "Купить подарок маме на др",
      "expected": {
        "categories_must_contain_any": ["покупки", "семья"],
        "is_multicategory": true
      }
    },
    {
      "id": "3.7",
      "title": "Помыть посуду и позвонить врачу",
      "expected": {
        "categories_count_min": 2,
        "note": "Два разных действия в одной задаче — допустимо иметь разные категории"
      }
    },
    {
      "id": "3.8",
      "title": "Закрыть рабочее задание на работе",
      "expected": {
        "categories_contains": ["работа"],
        "no_near_duplicates": true
      }
    }
  ]
}
