{
  "name": "study-cards",
  "version": "0.1.0",
  "description": "Mobile PNG-карточки (1080×1440) для учебных планов и статистики. Кириллица из коробки, light + dark темы, zero npm-зависимостей.",
  "main": "render.js",
  "bin": {
    "study-cards": "./render.js"
  },
  "scripts": {
    "plan": "node render.js",
    "stats": "node render-stats.js",
    "examples:plan": "cp examples/plan.example.json plan.json && node render.js",
    "examples:stats": "cp examples/tasks.example.yaml tasks.yaml && node render-stats.js"
  },
  "keywords": [
    "education",
    "study",
    "plan",
    "stats",
    "cards",
    "png",
    "telegram",
    "openclaw",
    "ege",
    "russian"
  ],
  "engines": {
    "node": ">=14"
  },
  "license": "MIT",
  "author": "study-cards contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/margoshkagt-star/Golden-Hour.git",
    "directory": "skills/study-cards"
  }
}
