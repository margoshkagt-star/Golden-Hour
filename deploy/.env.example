# ================================================================
# Golden Hour — Server Environment Variables
# Copy this to /opt/golden-hour/.env and fill in real values.
# Loaded by systemd (EnvironmentFile) and resolved inside openclaw.json
# via ${VAR} references. NEVER commit .env with real secrets.
# ================================================================

# --- LLM: MiniMax (primary model) ---  [REQUIRED]
# API key for the MiniMax provider (Anthropic-compatible endpoint).
MINIMAX_API_KEY=your_minimax_api_key_here

# --- LLM: local fallback model (Ollama) ---
# Model pulled by setup-server.sh and used as fallback when MiniMax fails.
# Must match the ollama model id in deploy/openclaw.config.json5.
# Small-VPS alternative: llama3.2:3b (lighter, ~2GB). Needs ~6-8GB RAM for 7b.
OLLAMA_FALLBACK_MODEL=qwen2.5:7b-instruct

# --- Telegram ---  [REQUIRED]
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- Google Calendar (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- OpenClaw gateway control plane ---
# Path to the resolved config file (systemd sets OPENCLAW_CONFIG_PATH to this).
OPENCLAW_CONFIG_PATH=/opt/golden-hour/.openclaw/openclaw.json
# Loopback-only by default — the gateway control plane is never exposed.
OPENCLAW_GATEWAY_BIND=loopback
# Non-standard high port (default 18789). Localhost-only; not opened in UFW.
OPENCLAW_GATEWAY_PORT=47854
# Auth token for the gateway control plane. Generate a random one:
#   openssl rand -hex 32
# setup-server.sh generates this automatically if left blank.
OPENCLAW_GATEWAY_TOKEN=

# --- Ports (application) ---
# SSH port is configured in sshd_config and set as GitHub Secret SSH_PORT
# (default 47822), NOT here.
#
# Internal application / health-check port.
APP_PORT=47832
# Telegram webhook port — ONLY needed if you switch from long-poll to webhook
# mode. Default deployment uses long-poll (outbound), so no inbound port is
# required. Webhook mode requires 443/80/88/8443 or a reverse proxy.
WEBHOOK_PORT=47843

# Note: HOME, NODE_ENV and TZ are set by the systemd unit (single source of
# truth) — do not duplicate them here, or .env would silently override them.
